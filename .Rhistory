# --- Load both summary result files ---
imdb <- read.csv("imdb_summary_results.csv")
agnews <- read.csv("agnews_summary_results.csv")
# --- Load both summary result files ---
imdb <- read.csv("imdb_summary_results.csv")
agnews <- read.csv("agnews_predictions_2k_bert.csv")
# --- Rename columns to match the paper format ---
colnames(imdb) <- c("Method", "SA_IMDB", "RA_IMDB", "Phi_IMDB")
colnames(agnews) <- c("Method", "SA_AGNews", "RA_AGNews", "Phi_AGNews")
# --- Merge the tables by Method ---
combined <- merge(imdb, agnews, by = "Method", all = TRUE)
# --- Optional: reorder rows to match paper's Table 7 ---
method_order <- c("Base", "Naïve-NoCal", "Naïve-Cal",
"B-CDF.05", "B-CDF.10", "B-CDF.50", "B-CDF.75", "B-CDF.95")
combined$Method <- factor(combined$Method, levels = method_order)
combined <- combined[order(combined$Method), ]
# --- Round values just for display ---
combined$SA_IMDB <- round(combined$SA_IMDB, 1)
combined$RA_IMDB <- round(combined$RA_IMDB, 1)
combined$Phi_IMDB <- round(combined$Phi_IMDB, 1)
combined$SA_AGNews <- round(combined$SA_AGNews, 1)
combined$RA_AGNews <- round(combined$RA_AGNews, 1)
combined$Phi_AGNews <- round(combined$Phi_AGNews, 1)
# --- Display the final table ---
print(combined)
# --- Optional: save to CSV ---
write.csv(combined, "combined_table7_results.csv", row.names = FALSE)
# --- Load AG News data ---
data <- read.csv("agnews_predictions_2k_bert.csv")
# --- Compute confidence ---
data$confidence <- pmax(data$softmax_class_0, data$softmax_class_1, data$softmax_class_2, data$softmax_class_3)
# --- Base method: No rejection ---
base_accuracy <- mean(data$predicted_label == data$true_label)
base_coverage <- 1
# --- Naïve-NoCal: Reject if confidence ≤ 0.5 ---
naive_threshold <- 0.5
data$decision <- ifelse(data$confidence > naive_threshold, "accept", "reject")
accepted <- subset(data, decision == "accept")
rejected <- subset(data, decision == "reject")
naive_nocal_sa <- if (nrow(accepted) > 0) {
mean(accepted$predicted_label == accepted$true_label)
} else { NA }
naive_nocal_ra <- if (nrow(rejected) > 0) {
mean(rejected$predicted_label == rejected$true_label)
} else { NA }
naive_nocal_phi <- nrow(accepted) / nrow(data)
# --- B-CDFδ Method ---
# 1. Try thresholds
thresholds <- seq(0.50, 0.99, by = 0.01)
results <- data.frame(
threshold = thresholds,
select_accuracy = NA,
reject_accuracy = NA,
coverage = NA,
p_value = NA
)
# 2. Loop through thresholds
for (i in seq_along(thresholds)) {
t <- thresholds[i]
# Decide accept/reject
data$decision <- ifelse(data$confidence > t, "accept", "reject")
# Split
accepted <- subset(data, decision == "accept")
rejected <- subset(data, decision == "reject")
# Select accuracy
select_acc <- if (nrow(accepted) > 0) {
mean(accepted$predicted_label == accepted$true_label)
} else { NA }
# Reject accuracy
reject_acc <- if (nrow(rejected) > 0) {
mean(rejected$predicted_label == rejected$true_label)
} else { NA }
# Coverage
coverage <- nrow(accepted) / nrow(data)
# Binomial test (random guess for 4 classes = 0.25)
p_value <- if (nrow(rejected) > 0) {
binom.test(
sum(rejected$predicted_label == rejected$true_label),
nrow(rejected),
p = 0.25,
alternative = "greater"
)$p.value
} else { NA }
# Store
results[i, ] <- c(t, select_acc, reject_acc, coverage, p_value)
}
# 3. Evaluate for δ values
delta_list <- c(0.05, 0.10, 0.50, 0.75, 0.95)
summary_results <- data.frame()
for (d in delta_list) {
valid <- subset(results, p_value > d)
if (nrow(valid) > 0) {
best_row <- valid[which.max(valid$select_accuracy), ]
summary_results <- rbind(summary_results, cbind(delta = d, best_row))
} else {
cat("δ =", d, "→ No valid threshold found.\n")
}
}
# 4. Match reject accuracy for summary table
b_cdf_ras <- sapply(summary_results$threshold, function(th) {
row <- results[which(results$threshold == th), ]
return(row$reject_accuracy)
})
# 5. Final table like Table 7
summary_table <- data.frame(
Method = c(
"Base",
"Naïve-NoCal",
paste0("B-CDF.", gsub("^0\\.", "", formatC(summary_results$delta, format = "f", digits = 2)))
),
SA = round(c(base_accuracy, naive_nocal_sa, summary_results$select_accuracy) * 100, 1),
RA = round(c(NA, naive_nocal_ra, b_cdf_ras) * 100, 1),
Coverage = round(c(base_coverage, naive_nocal_phi, summary_results$coverage) * 100, 1)
)
